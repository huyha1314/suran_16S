# =========================================================================
#        🧬 16S Hybrid Short/Long-Read Pipeline Configuration Panel
# =========================================================================
# Single source of truth for ALL pipeline and report settings.
# Sourced automatically by 'master.sh' and 'rp.sh'.
# To run the full pipeline:  pixi run all
# To rebuild the report only: bash rp.sh

# -------------------------------------------------------------------------
# 1. Pipeline Mode Switch
# -------------------------------------------------------------------------
# Choose your sequencing analysis type:
# - 'shortread' : DADA2 exact amplicon sequence variants (ASVs) for V3-V4 Illumina
# - 'longread'  : Emu + Kraken2/Bracken species-level taxonomy for ONT long reads
export MODE="longread"

# -------------------------------------------------------------------------
# 2. Project Identity
# -------------------------------------------------------------------------
# Used as the base name for the output archives (.tar.gz and .zip).
# Example: PROJECT_NAME="my_study_2026" → my_study_2026.tar.gz
export PROJECT_NAME="16S_analysis"

# -------------------------------------------------------------------------
# 3. Parallel Computing & Thread Allocations
# -------------------------------------------------------------------------
export THREADS=64                                     # Global cores fallback limit
export MD5_THREADS=${THREADS}                         # Cores for parallel MD5 hashing
export FASTQC_THREADS=${THREADS}                      # Cores for FastQC and NanoPlot
export TRIM_CONCURRENCY=8                             # Concurrent samples trimmed in parallel
export TRIM_THREADS_PER_JOB=8                         # CPU threads per trimmer job (8×8 = 64)
export DADA2_THREADS=${THREADS}                       # Cores for DADA2/Minimap2/Emu steps
export PICRUST2_THREADS=${THREADS}                    # Cores for PICRUSt2 forecasting

# -------------------------------------------------------------------------
# 4. Input Data & Metadata Paths
# -------------------------------------------------------------------------
export DATA_DIR="./data"                              # Directory containing raw FASTQ files
export SAMPLE_TSV="./sample.tsv"                      # Standardized sample sheet (auto-generated)
export METADATA_PATH="./metadata.tsv"                 # Longitudinal metadata table

# -------------------------------------------------------------------------
# 5. Output Directory Structure
# -------------------------------------------------------------------------
export RESULTS_DIR="./results"
export QC_DIR="${RESULTS_DIR}/01_trimmed/qc"
export TRIM_DIR="${RESULTS_DIR}/01_trimmed"
export DADA2_DIR="${RESULTS_DIR}/02_dada2"
export PHYLO_DIR="${RESULTS_DIR}/03_phyloseq"
export STATS_DIR="${RESULTS_DIR}/04_stats"
export NETWORK_DIR="${RESULTS_DIR}/05_network"
export PICRUSt2_DIR="${RESULTS_DIR}/06_picrust2"
export DB_DIR="./data/db"

# -------------------------------------------------------------------------
# 6. Custom Database Override Paths (BYPASS ZENODO DOWNLOADS)
# -------------------------------------------------------------------------
# If you have already downloaded your reference database files, set paths here.
# When specified, the pipeline skips Stage 2 (database downloading).
export SILVA_TRAIN_FILE="/worker_data2/huyha/precisiongene/16S_suran/16S_shortread_analysis/data/db/silva_nr99_v138.1_train_set.fa.gz"
export SILVA_SPECIES_FILE="/worker_data2/huyha/precisiongene/16S_suran/16S_shortread_analysis/data/db/silva_species_assignment_v138.1.fa.gz"

# -------------------------------------------------------------------------
# 7. Long-Read (ONT) Amplicon Parameters
# -------------------------------------------------------------------------
export FILTLONG_MIN_LEN=800                           # Filtlong minimum read length threshold (bp)
export FILTLONG_MIN_Q=10                              # Filtlong minimum mean quality threshold (Q score)
export PRIMER_F_LONG="AGAGTTTGATCMTGGCTCAG"           # Universal full-length forward primer (27F)
export PRIMER_R_LONG="CGGTTACCTTGTTACGACTT"           # Universal full-length reverse primer (1492R)

# -------------------------------------------------------------------------
# 8. Short-Read (Illumina) Amplicon & DADA2 Parameters
# -------------------------------------------------------------------------
export PRIMER_F="CCTACGGGNGGCWGCAG"                   # Forward primer (341F)
export PRIMER_R="GACTACHVGGGTATCTAATCC"               # Reverse primer (805R)
export TRUNC_LEN_F=270                                # Illumina forward truncation length (bp)
export TRUNC_LEN_R=210                                # Illumina reverse truncation length (bp)
export MAX_EE_F=2                                     # Max expected errors — forward read
export MAX_EE_R=5                                     # Max expected errors — reverse read
